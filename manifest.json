{
  "manifest_version": 3,
  "name": "Google Account Router",
  "version": "1.0.0",
  "description": "Redireciona servicos Google selecionados para o indice de conta configurado.",
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://mail.google.com/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Google Account Router",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
